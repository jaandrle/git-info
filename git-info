#!/usr/bin/env bash

set -euo pipefail

# --- Theme Configuration ---
readonly COLOR_ACCENT='\033[33m'  # Orange
readonly COLOR_BRANCH='\033[34m'  # Blue
readonly COLOR_STRONG='\033[1m'   # Bold
readonly COLOR_OK='\033[32m'      # Green
readonly COLOR_KO='\033[31m'      # Red
readonly COLOR_NOTE='\033[37;2m'  # GRAY

readonly SEP='┊'

# --- Internal ---
readonly COLOR_RESET='\033[0m'
readonly COLOR_DIM='\033[2m'

# --- Formatting Helpers ---
fmt_hash() { # Formats a 7-char hash with a 4/3 color split
	local hash="$1"
	# First 4 chars in accent color, last 3 dimmed 
	echo -ne "${COLOR_ACCENT}${hash:0:4}${COLOR_DIM}${hash:4:3}${COLOR_RESET}"
}

render_header() { # Renders consistent branch/section headers
	local type="$1"
	local label="$2"
	case "$type" in
		"unstaged") echo -e "${COLOR_NOTE}╭┄ [$label]${COLOR_RESET}" ;;
		"staged") echo -e "${COLOR_NOTE}├┄ [$label]${COLOR_RESET}" ;;
		"branch")   echo -e "${SEP}${COLOR_NOTE}╭┄ [${COLOR_STRONG}${COLOR_BRANCH}${label}${COLOR_RESET}${COLOR_NOTE}]${COLOR_RESET}" ;;
		"stacked")  echo -e "${SEP}${COLOR_NOTE}├┄ [${COLOR_STRONG}${COLOR_BRANCH}${label}${COLOR_RESET}${COLOR_NOTE}]${COLOR_RESET}" ;;
	esac
}

get_dot() { # Checks remote status for the commit dot 
	local hash="$1"
	if git branch -r --contains "$hash" 2>/dev/null | grep -q "origin/"; then
		echo -e "${COLOR_OK}●${COLOR_RESET}"
	else
		echo -e "${COLOR_RESET}●${COLOR_RESET}"
	fi
}

get_default_branch() { # Detects the default branch from remote
	# Try to get the default branch from remote using git remote show
	local default_branch=""
	local remote="origin"
	
	# Method 1: Use git remote show to find HEAD branch
	default_branch=$(git remote show "$remote" 2>/dev/null | grep "HEAD branch" | sed 's/.*: //' | tr -d ' \n')
	
	if [[ -n "$default_branch" ]]; then
		echo "$remote/$default_branch"
		return
	fi
	
	# Method 2: Fallback to common default branches
	local common_branches=("main" "master" "develop" "trunk")
	for branch in "${common_branches[@]}"; do
		if git show-ref --verify --quiet "refs/remotes/$remote/$branch" 2>/dev/null; then
			echo "$remote/$branch"
			return
		fi
	done
	
	# Method 3: Fallback to origin/main as ultimate fallback
	echo "$remote/main"
}

main() {
	if [[ "${1:-}" == "help" ]]; then
		echo "Git status inspired GitButtler cli."
		echo "Usage: git s"
		exit 0
	fi
	
	# Detect default branch
	local DEFAULT_BRANCH
	DEFAULT_BRANCH=$(get_default_branch)
	
	# Pre-fetch numstat for all files to avoid multiple git diff calls
	local numstat_cache
	declare -A numstat_cache
	while IFS= read -r line; do
		local additions deletions file
		read -r additions deletions file <<< "$line"
		numstat_cache["$file"]="${additions}+${deletions}-"
	done < <(git diff --numstat 2>/dev/null || true)
	
	# 1. Unstaged changes section 
	render_header "unstaged" "unstaged changes"

	local staget
	staget=$(git diff --cached --name-status 2>/dev/null || true)
	
	git status --short --no-branch 2>/dev/null | while read -r line; do
		local STAT
		local FILE
		local LAST_HASH
		local COLOR
		local NUMSTAT
		
		STAT="${line%% *}"
		FILE="${line#* }"

		for sline in $staget; do
			if [ "$FILE" == "$sline" ]; then
				continue 2
			fi
		done

		if [[ "$STAT" == "??" || "$STAT" == "A" ]]; then
			LAST_HASH="${COLOR_NOTE}new file${COLOR_RESET}"
			STAT="A"
			COLOR="$COLOR_OK"
			NUMSTAT=""
		else
			# Fetch and format the last hash to touch this file 
			local RAW_HASH
			RAW_HASH=$(git log -1 --format="%h" -- "$FILE" 2>/dev/null || echo "")
			LAST_HASH=$(fmt_hash "$RAW_HASH")
			case "$STAT" in
				"M") COLOR="$COLOR_ACCENT" ;;
				"D") COLOR="$COLOR_KO"    ;;
				*)   COLOR="$COLOR_ACCENT" ;;
			esac
			# Get numstat from cache
			NUMSTAT=${numstat_cache["$FILE"]:-}
		fi

		# Aligned output: Status | File | Spacer | Last Hash | Numstat
		printf "${SEP}   ${COLOR}%s${COLOR_RESET} %s ${COLOR_NOTE}%s …${COLOR_RESET} %b\n" "$STAT" "$FILE" "$NUMSTAT" "$LAST_HASH"
	done
	echo -e "$SEP"

	if [ -n "$staget" ]; then
		render_header "staged" "staged changes"
		while read -r line; do
			local STAT
			local FILE
			
			STAT="${line%% *}"
			FILE="${line#* }"
			printf "${SEP}   ${COLOR_OK}%s${COLOR_RESET} %s\n" "$STAT" "$FILE"
		done <<< "$staget"
		echo -e "$SEP"
	fi

	# 2. Dynamic Commit Groups 
	local CURRENT_GROUP
	CURRENT_GROUP=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
	render_header "branch" "$CURRENT_GROUP"
	local TARGET_HASH=""

	while IFS='|' read -r HASH REFS MSG AUTHT AUTHU; do
		if [[ -n "$REFS" ]]; then
			# Clean refs: remove HEAD pointers and tag prefixes using bash string replacement
			local CLEAN_REFS
			CLEAN_REFS="${REFS//HEAD -> /}"
			CLEAN_REFS="${CLEAN_REFS//tag: /}"

			# Detect if we hit the target/upstream branch using bash string search
			if [[ "$CLEAN_REFS" == *"$DEFAULT_BRANCH"* ]]; then
				TARGET_HASH="$HASH"
				local TARGET_REF
				# Use bash array and loop instead of echo | tr | sed | grep pipeline
				IFS=',' read -ra REFS_ARRAY <<< "$CLEAN_REFS"
				for ref in "${REFS_ARRAY[@]}"; do
					ref="${ref#"${ref%%[![:space:]]*}"}"  # trim leading whitespace
					if [[ "$ref" == "$DEFAULT_BRANCH" ]]; then
						TARGET_REF="$ref"
						break
					fi
					done
				break
			fi

			# Detect a new local branch label (Stacked branches) using bash array
			local NEW_GROUP=""
			IFS=',' read -ra REFS_ARRAY <<< "$CLEAN_REFS"
			for ref in "${REFS_ARRAY[@]}"; do
				ref="${ref#"${ref%%[![:space:]]*}"}"  # trim leading whitespace
				if [[ "$ref" != *"origin/"* && "$ref" != *"gitbutler/"* && "$ref" != "$CURRENT_GROUP" ]]; then
					NEW_GROUP="$ref"
					break
				fi
				done
			if [[ -n "$NEW_GROUP" && "$NEW_GROUP" != "$CURRENT_GROUP" ]]; then
				CURRENT_GROUP="$NEW_GROUP"
				echo -e "${SEP}${COLOR_NOTE}│${COLOR_RESET}"
				render_header "stacked" "$CURRENT_GROUP"
			fi
		fi

		echo -e "${SEP}$(get_dot "$HASH")   $(fmt_hash "$HASH") $MSG $COLOR_NOTE($AUTHT · $AUTHU)${COLOR_RESET}"
	done < <(git log --format="%h|%D|%s|%ar|%an" HEAD 2>/dev/null || true)

	# 3. Footer Section 
	[[ -z "$TARGET_HASH" ]] && TARGET_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo "") && TARGET_REF="unknown"

	local F_DATE
	local F_MSG
	F_DATE=$(git show -s --format='%as' "$TARGET_HASH" 2>/dev/null || echo "")
	F_MSG=$(git show -s --format='%s' "$TARGET_HASH" 2>/dev/null || echo "")

	echo -e "${COLOR_NOTE}├╯${COLOR_RESET}\n$SEP"
	echo -e "┴ $(fmt_hash "$TARGET_HASH") ${COLOR_STRONG}[${COLOR_BRANCH}${TARGET_REF}${COLOR_RESET}${COLOR_STRONG}]${COLOR_RESET} ${COLOR_DIM}${F_DATE}${COLOR_RESET} ${COLOR_DIM}${F_MSG}${COLOR_RESET}"
	# white dim
	echo -e "\n\e[37m${COLOR_NOTE}Hint: run \`git diff\` to see changes or \`git add\` to stage${COLOR_RESET}"
}

main "$@"
