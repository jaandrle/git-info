#!/usr/bin/env bash
set -euo pipefail

# --- Theme Configuration ---
readonly COLOR_ACCENT='\033[34m'      # Blue
readonly COLOR_SECTION='\033[32m'     # Green
readonly COLOR_SECTION_ALT='\033[36m' # Cyan
readonly COLOR_STRONG='\033[1m'       # Bold
readonly COLOR_OK='\033[32m'          # Green
readonly COLOR_WARN='\033[33m'        # Orange
readonly COLOR_KO='\033[31m'          # Red
readonly COLOR_NOTE='\033[37;2m'      # GRAY

readonly SEP='┊'

# --- Internal ---
readonly VERSION="1.2.0"
readonly COLOR_RESET='\033[0m'
readonly COLOR_DIM='\033[2m'

# --- Functions ---
fmt_hash() { # formats a 7-char hash with first 4 chars in accent color, last 3 dimmed 
	local hash="$1"
	echo -ne "${COLOR_ACCENT}${hash:0:4}${COLOR_DIM}${hash:4:3}${COLOR_RESET}"
}
fmt_label() {
	local mode="${1:-accent}" # accent, normal
	local label="${2:-}"
	local color="${COLOR_SECTION}"
	if [[ "$mode" == "normal" ]]; then
		color="${COLOR_SECTION_ALT}"
	fi
	printf "[${COLOR_STRONG}${color}%s${COLOR_RESET}]" \
		"$label"
}
fmt_auth() {
	local user="$1"
	local relative="$2"
	printf "$COLOR_NOTE(%s · %s)${COLOR_RESET}" \
		"$user" "$relative"
}
echo_header() { # branch/section headers
	local type="$1"
	local label="$2"
	case "$type" in
		"unstaged") echo -e "╭┄┄ $(fmt_label normal "$label")" ;;
		"staged") echo -e "${SEP}╭┄┄ $(fmt_label normal "$label")" ;;
		"branch")   echo -e "${SEP}╭┄ $(fmt_label accent "$label")" ;;
		"stacked")  echo -e "${SEP}├┄ $(fmt_label accent "$label")" ;;
	esac
}
echo_remote_status() { # Checks remote status for the commit dot 
	local status="${1:-}" # 1 = on remote, 0 = not on remote
	if [[ "$status" == "1" ]]; then
		echo -e "${COLOR_OK}●${COLOR_RESET}"
	else
		echo -e "${COLOR_RESET}◐${COLOR_RESET}"
	fi
}
echo_file_entry() { # Prints a file entry with consistent formatting
	local status="$1"
	local file="$2"
	local context="$3" # unstaged, staged, or stashed
	local hash="${4:-}"    # Optional: last commit hash
	local numstat="${5:-}" # Optional: numstat string
	
	local color=""
	local status_char=""
	local hash_display=""
	
	status_char="${status:0:1}"
	
	# Set color based on status
	case "$status_char" in
		"M") color="${COLOR_WARN}" ;;
		"D") color="${COLOR_KO}"    ;;
		"A") color="${COLOR_OK}"    ;;
		*)   color="${COLOR_ACCENT}" ;;
	esac
	
	# Set hash display
	if [[ -n "$hash" ]]; then
		hash_display="$hash"
	else
		hash_display="${COLOR_NOTE}new file${COLOR_RESET}"
	fi
	
	# Print the formatted file entry
	if [[ "$context" == "staged" || "$context" == "commit" ]]; then
		printf "${SEP}│   %s ${color}%s${COLOR_RESET}\n" \
			"$status_char" "$file"
	else
		printf "${SEP}    %s ${color}%s${COLOR_RESET} ${COLOR_NOTE}%s …${COLOR_RESET} %b\n" \
			"$status_char" "$file" "$numstat" "$hash_display"
	fi
}
get_in_progress() { # Detects rebase/merge/cherry-pick/revert in progress and outputs operation type
	local state_dir=""
	local operation=""

	if [[ -d .git/rebase-merge ]]; then
		state_dir=".git/rebase-merge"
		if [[ -f "$state_dir/interactive" ]]; then
			operation="rebase"
		else
			operation="rebase"
		fi
	elif [[ -d .git/rebase-apply ]]; then
		operation="rebase"
	elif [[ -f .git/MERGE_HEAD ]]; then
		operation="merge"
	elif [[ -f .git/CHERRY_PICK_HEAD ]]; then
		operation="cherry-pick"
	elif [[ -f .git/REVERT_HEAD ]]; then
		operation="revert"
	fi

	echo "$operation"
}
echo_in_progress() { # Renders rebase/merge/cherry-pick/revert in progress
	local state_dir=""
	local operation=""
	local step=""
	local total=""

	if [[ -d .git/rebase-merge ]]; then
		state_dir=".git/rebase-merge"
		if [[ -f "$state_dir/interactive" ]]; then
			operation="rebase -i"
		else
			operation="rebase"
		fi
		step=$(cat "$state_dir/msgnum" 2>/dev/null || echo "1")
		total=$(cat "$state_dir/end" 2>/dev/null || echo "?")
	elif [[ -d .git/rebase-apply ]]; then
		state_dir=".git/rebase-apply"
		operation="rebase"
		step=$(cat "$state_dir/next" 2>/dev/null || echo "1")
		total=$(cat "$state_dir/last" 2>/dev/null || echo "?")
	elif [[ -f .git/MERGE_HEAD ]]; then
		operation="merge"
		step=""
		total=""
	elif [[ -f .git/CHERRY_PICK_HEAD ]]; then
		operation="cherry-pick"
		step=""
		total=""
	elif [[ -f .git/REVERT_HEAD ]]; then
		operation="revert"
		step=""
		total=""
	fi

	if [[ -z "$operation" ]]; then
		return 0
	fi
	
	local color="${COLOR_WARN}"
	if [[ "$operation" == "merge" ]]; then
		color="${COLOR_ACCENT}"
	fi
	if [[ -n "$step" && -n "$total" && "$total" != "?" ]]; then
		echo -e "${color}! $operation ($step/$total)${COLOR_RESET}"
	else
		echo -e "${color}! $operation${COLOR_RESET}"
	fi
	echo
}
get_default_branch() { # Detects the default branch from remote
	local default_branch=""
	local remote="origin"
	
	# Method 1: Check local config for default branch (fast, no network)
	default_branch=$(git config "remote.$remote.branch.default" 2>/dev/null || true)
	if [[ -n "$default_branch" ]]; then
		echo "$remote/$default_branch"
		return
	fi
	
	# Method 2: Try to get from git symbolic-ref (very fast)
	local head_ref
	head_ref=$(git symbolic-ref "refs/remotes/$remote/HEAD" 2>/dev/null || true)
	if [[ -n "$head_ref" ]]; then
		echo "${head_ref#refs/remotes/}"
		return
	fi
	
	# Method 3: Fallback to common default branches
	local common_branches=("main" "master" "develop" "trunk")
	for branch in "${common_branches[@]}"; do
		if git show-ref --verify --quiet "refs/remotes/$remote/$branch" 2>/dev/null; then
			echo "$remote/$branch"
			return
		fi
	done
	
	# Method 4: Ultimate fallback
	echo "$remote/main"
}

main() {
	if [[ "${1:-}" == "--version" ]]; then
		echo "$VERSION"
		exit 0
	fi
	if [[ "${1:-}" == "help" ]] || [[ "${1:-}" == "--help" ]]; then
		echo "Git status inspired by GitButler CLI."
		echo ""
		echo "Usage:"
		echo "  git-info          Show git status"
		echo "  git-info -f       Show git status with commit files"
		echo "  git-info help     Show this help message"
		echo "  git-info --help   Show this help message"
		echo ""
		echo "Description:"
		echo "  A colorful and informative Git status tool that displays unstaged changes,"
		echo "  staged changes, commit history, and branch information."
		echo ""
		echo "Options:"
		echo "  -f                Show files for each commit in history"
		echo ""
		echo "UI Elements:"
		echo "  ╭┄ [section]     Section headers (branch/staged/unstaged)"
		echo "  ●                Commit on remote (green)"
		echo "  ◐                Commit not on remote yet"
		echo "  ! operation      In-progress Git operation"
		echo "  M/A/D            File status (Modified/Added/Deleted)"
		echo "  ┴ hash [branch]  Footer with target branch info"
		echo "  Hint:            Contextual hint"
		exit 0
	fi
	
	# Parse flags
	local show_files=false
	while getopts "f" opt; do
		case $opt in
			f)
				show_files=true
				;;
			\?)
				echo "Invalid option: -$OPTARG" >&2
				exit 1
				;;
		esac
	done
	
	# Detect default branch
	local DEFAULT_BRANCH
	DEFAULT_BRANCH=$(get_default_branch)
	
	# Pre-fetch numstat and staged files
	declare -A numstat_cache staged_files_cache
	numstat_cache=()
	staged_files_cache=()
	
	# Pre-fetch numstat
	while IFS= read -r line || [[ -n "$line" ]]; do
		local additions='' deletions='' file=''
		read -r additions deletions file <<< "$line"
		[[ -z "$file" ]] && continue
		numstat_cache["$file"]="${additions}+${deletions}-"
	done < <(git diff --numstat 2>/dev/null)
	
	# Pre-fetch staged files - parse tab-separated output
	while IFS=$'\t' read -r stat file || [[ -n "$stat" ]]; do
		[[ -z "$file" ]] && continue
		staged_files_cache["$file"]="$stat"
	done < <(git diff --cached --name-status 2>/dev/null)
	
	local has_unstaged=false
	local has_staged=false
	if [[ -n "${numstat_cache:+x}" || -n "${staged_files_cache:+x}" ]]; then
		if [[ ${#numstat_cache[@]} -gt 0 ]]; then
			has_unstaged=true
		fi
		if [[ ${#staged_files_cache[@]} -gt 0 ]]; then
			has_staged=true
		fi
	else
		if git status --short --no-branch 2>/dev/null | grep -q .; then
			has_unstaged=true
		fi
		if git diff --cached --name-status 2>/dev/null | grep -q .; then
			has_staged=true
		fi
	fi
	
	# 0. Check for in-progress operations
	echo_in_progress

	# 1. Unstaged changes section 
	echo_header "unstaged" "unstaged changes"
	
	if [[ $has_unstaged != true ]]; then
		local COLOR_EMPHASIS="\e[3m"
		echo -e "${SEP}    ${COLOR_EMPHASIS}no changes${COLOR_RESET}"
	else
		git status --short --no-branch 2>/dev/null | while IFS= read -r line; do
			local STAT
			local FILE
			local LAST_HASH
			local NUMSTAT
			
			STAT="${line:0:2}"
			FILE="${line:3}"

			[[ -z "$FILE" ]] && continue
			[[ "${STAT:1:1}" == " " ]] && continue

			local UNSTAGED_STAT="${STAT:1:1}"
			if [[ "$STAT" == "?" || "$STAT" == "A" || "$UNSTAGED_STAT" == "?" || "$UNSTAGED_STAT" == "A" ]]; then
				LAST_HASH=""
				UNSTAGED_STAT="A"
				NUMSTAT=""
			else
				# Fetch and format the last hash to touch this file 
				local RAW_HASH
				RAW_HASH=$(git log -1 --format="%h" -- "$FILE" 2>/dev/null || echo "")
				LAST_HASH=$(fmt_hash "$RAW_HASH")
				# Get numstat from cache
				NUMSTAT=${numstat_cache["$FILE"]:-}
			fi

			# Use the DRY function to print file entry
			echo_file_entry "$UNSTAGED_STAT" "$FILE" "unstaged" "$LAST_HASH" "$NUMSTAT"
		done
	fi
	echo -e "$SEP"
	
	# 1.5 Stashed changes section - individual sections for each stash
	local stashed_entries
	stashed_entries=$(git stash list --format="%gd:%gs" 2>/dev/null || echo "")
	if [[ -n "$stashed_entries" ]]; then
		# Process each stash entry as a separate section
		while IFS=':' read -r stash_index stash_branch stash_message; do
			# On branch → branch
			stash_branch="${stash_branch/On /}"
			stash_message="${stash_message#"${stash_message%%[![:space:]]*}"}"
			if [[ -n "$stash_index" ]]; then
				# Create section header for each stash with formatted index
				printf "├┄┄ [${COLOR_STRONG}${COLOR_SECTION}%s${COLOR_RESET} ${COLOR_SECTION_ALT}%s${COLOR_RESET}] %s\n" \
					"$stash_branch" "$stash_index" "$stash_message"
				
					# Show stash files if available - similar to unstaged/staged format
					local stash_files
					stash_files=$(git stash show --include-untracked --name-status "$stash_index" 2>/dev/null)
					if [[ -n "$stash_files" ]]; then
						while IFS= read -r line; do
							if [[ -n "$line" ]]; then
								local STAT
								local FILE
								local LAST_HASH
								local NUMSTAT
								
								STAT="${line:0:1}"
								FILE="${line:2}"
								
								[[ -z "$FILE" ]] && continue
								
								if [[ "$STAT" == "A" ]]; then
									LAST_HASH=""
									NUMSTAT=""
								else
									# Fetch and format the last hash to touch this file 
									local RAW_HASH
									RAW_HASH=$(git log -1 --format="%h" -- "$FILE" 2>/dev/null || echo "")
									LAST_HASH=$(fmt_hash "$RAW_HASH")
									# Get numstat for this file
									NUMSTAT=$(git diff --numstat "$stash_index^..$stash_index" -- "$FILE" 2>/dev/null | awk '{print $1"+"$2"-"}' || echo "")
								fi
								
								echo_file_entry "$STAT" "$FILE" "stashed" "$LAST_HASH" "$NUMSTAT"
							fi
							done <<< "$stash_files"
					fi
				
				# Separator between stashes
				echo -e "${SEP}"
			fi
		done <<< "$stashed_entries"
	fi
	
	if [[ $has_staged == true ]]; then
		echo_header "staged" "staged changes"
		for file in "${!staged_files_cache[@]}"; do
			local STAT="${staged_files_cache[$file]:0:1}"
			echo_file_entry "$STAT" "$file" "staged"
		done
		echo -e "${SEP}│"
	fi
	
	# 2. Dynamic Commit Groups 
	local CURRENT_GROUP
	CURRENT_GROUP=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
	if [[ ${#staged_files_cache[@]} -gt 0 ]]; then
		echo_header "stacked" "$CURRENT_GROUP"
	else
		echo_header "branch" "$CURRENT_GROUP"
	fi
	local TARGET_HASH=""
	local TARGET_REF=""
	
	# Cache branch contains checks
	declare -A branch_contains_cache
	
	while IFS='|' read -r HASH REFS MSG AUTHT AUTHU; do
		if [[ -n "$REFS" ]]; then
			# Clean refs: remove HEAD pointers and tag prefixes using bash string replacement
			local CLEAN_REFS
			CLEAN_REFS="${REFS//HEAD -> /}"
			CLEAN_REFS="${CLEAN_REFS//tag: /}"

			# Check if we hit the target/upstream branch
			if [[ "$CLEAN_REFS" == *"$DEFAULT_BRANCH"* ]]; then
				TARGET_HASH="$HASH"
				# Extract target ref
				IFS=',' read -ra REFS_ARRAY <<< "$CLEAN_REFS"
				for ref in "${REFS_ARRAY[@]}"; do
					ref="${ref#"${ref%%[![:space:]]*}"}"  # trim leading whitespace
					if [[ "$ref" == "$DEFAULT_BRANCH" ]]; then
						TARGET_REF="$ref"
						break 2
					fi
				done
			fi

			# Detect a new local branch label (Stacked branches) using bash array
			local NEW_GROUP=""
			IFS=',' read -ra REFS_ARRAY <<< "$CLEAN_REFS"
			for ref in "${REFS_ARRAY[@]}"; do
				ref="${ref#"${ref%%[![:space:]]*}"}"  # trim leading whitespace
				if [[ "$ref" != *"origin/"* && "$ref" != *"gitbutler/"* && "$ref" != "$CURRENT_GROUP" ]]; then
					NEW_GROUP="$ref"
					break
				fi
				done
			if [[ -n "$NEW_GROUP" && "$NEW_GROUP" != "$CURRENT_GROUP" ]]; then
				CURRENT_GROUP="$NEW_GROUP"
				echo -e "${SEP}│"
				echo_header "stacked" "$CURRENT_GROUP"
			fi
		fi

		# Cache branch contains check result
		if [[ -z "${branch_contains_cache[$HASH]:-}" ]]; then
			if git branch -r --contains "$HASH" 2>/dev/null | grep -q "origin/"; then
				branch_contains_cache["$HASH"]="1"
			else
				branch_contains_cache["$HASH"]="0"
			fi
		fi

		local DOT
		DOT=$(echo_remote_status "${branch_contains_cache[$HASH]:-}")
		echo -e "${SEP}$DOT   $(fmt_hash "$HASH") $MSG $(fmt_auth "$AUTHU" "$AUTHT")"
		
		# Show commit files if -f flag is provided
		if [[ "$show_files" == true ]]; then
			while IFS= read -r line; do
				if [[ -n "$line" ]]; then
					local STAT
					local FILE
					
					STAT="${line:0:1}"
					FILE="${line:2}"
					
					[[ -z "$FILE" ]] && continue
					
					# Use echo_file_entry function with commit context
					echo_file_entry "$STAT" "$FILE" "commit"
				fi
			done < <(git show --name-status --format="" "$HASH" 2>/dev/null || echo "")
		fi
	done < <(git log --format="%h|%D|%s|%ar|%an" HEAD 2>/dev/null || echo "")
	
	# 3. Footer Section 
	if [[ -z "$TARGET_HASH" ]]; then
		TARGET_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo "")
		TARGET_REF="unknown"
	fi
	
	local TARGET_DATE=""
	local TARGET_MSG=""
	local TARGET_AUTHOR=""
	# Fetch target commit info in one call if not already cached
	if [[ -z "$TARGET_DATE" || -z "$TARGET_MSG" ]]; then
		local target_info
		target_info=$(git show -s --format='%ar|%an|%s' "$TARGET_HASH" 2>/dev/null || echo "")
		IFS='|' read -r TARGET_DATE TARGET_AUTHOR TARGET_MSG <<< "$target_info"
	fi
	
	echo -e "├╯\n$SEP"
	echo -e "┴ $(fmt_hash "$TARGET_HASH") $(fmt_label accent "$TARGET_REF") ${TARGET_MSG} $(fmt_auth "$TARGET_AUTHOR" "$TARGET_DATE")"
	
	local HINT=""
	local IN_PROGRESS_OP
	IN_PROGRESS_OP=$(get_in_progress)
	if [[ -n "$IN_PROGRESS_OP" ]]; then
		case "$IN_PROGRESS_OP" in
			"rebase")      HINT="resolve conflicts, \`git add\`, then \`git rebase --continue\`" ;;
			"merge")       HINT="resolve conflicts, \`git add\`, then \`git commit\`" ;;
			"cherry-pick") HINT="resolve conflicts, \`git add\`, then \`git cherry-pick --continue\`" ;;
			"revert")      HINT="resolve conflicts, \`git add\`, then \`git revert --continue\`" ;;
		esac
	else
		if $has_staged; then
			HINT="run \`git commit\` to commit staged changes"
		elif $has_unstaged; then
			HINT="run \`git diff\` to see changes, \`git add\` to stage"
		fi
	fi
	if [[ -n "$HINT" ]]; then
		echo -e "\n\e[37m${COLOR_NOTE}Hint: ${HINT}${COLOR_RESET}"
	fi
}

# --- Execution ---
main "$@"
