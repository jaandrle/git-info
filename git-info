#!/usr/bin/env bash

set -euo pipefail

# --- Theme Configuration ---
readonly COLOR_ACCENT='\033[33m'  # Orange
readonly COLOR_BRANCH='\033[34m'  # Blue
readonly COLOR_STRONG='\033[1m'   # Bold
readonly COLOR_OK='\033[32m'      # Green
readonly COLOR_KO='\033[31m'      # Red
readonly COLOR_NOTE='\033[37;2m'  # GRAY

readonly SEP='┊'

# --- Internal ---
readonly VERSION="1.0.0"
readonly COLOR_RESET='\033[0m'
readonly COLOR_DIM='\033[2m'

# --- Functions ---
fmt_hash() { # formats a 7-char hash with a 4/3 color split
	local hash="$1"
	# First 4 chars in accent color, last 3 dimmed 
	echo -ne "${COLOR_ACCENT}${hash:0:4}${COLOR_DIM}${hash:4:3}${COLOR_RESET}"
}
render_header() { # branch/section headers
	local type="$1"
	local label="$2"
	case "$type" in
		"unstaged") echo -e "${COLOR_NOTE}╭┄ [$label]${COLOR_RESET}" ;;
		"staged") echo -e "${SEP}${COLOR_NOTE}╭┄ [$label]${COLOR_RESET}" ;;
		"branch")   echo -e "${SEP}${COLOR_NOTE}╭┄ [${COLOR_STRONG}${COLOR_BRANCH}${label}${COLOR_RESET}${COLOR_NOTE}]${COLOR_RESET}" ;;
		"stacked")  echo -e "${SEP}${COLOR_NOTE}├┄ [${COLOR_STRONG}${COLOR_BRANCH}${label}${COLOR_RESET}${COLOR_NOTE}]${COLOR_RESET}" ;;
	esac
}
echo_remote_status() { # Checks remote status for the commit dot 
	local status="${1:-}" # 1 = on remote, 0 = not on remote
	if [[ "$status" == "1" ]]; then
		echo -e "${COLOR_OK}●${COLOR_RESET}"
	else
		echo -e "${COLOR_RESET}◐${COLOR_RESET}"
	fi
}
get_in_progress() { # Detects rebase/merge/cherry-pick/revert in progress and outputs operation type
	local state_dir=""
	local operation=""

	if [[ -d .git/rebase-merge ]]; then
		state_dir=".git/rebase-merge"
		if [[ -f "$state_dir/interactive" ]]; then
			operation="rebase"
		else
			operation="rebase"
		fi
	elif [[ -d .git/rebase-apply ]]; then
		operation="rebase"
	elif [[ -f .git/MERGE_HEAD ]]; then
		operation="merge"
	elif [[ -f .git/CHERRY_PICK_HEAD ]]; then
		operation="cherry-pick"
	elif [[ -f .git/REVERT_HEAD ]]; then
		operation="revert"
	fi

	echo "$operation"
}
echo_in_progress() { # Renders rebase/merge/cherry-pick/revert in progress
	local state_dir=""
	local operation=""
	local step=""
	local total=""

	if [[ -d .git/rebase-merge ]]; then
		state_dir=".git/rebase-merge"
		if [[ -f "$state_dir/interactive" ]]; then
			operation="rebase -i"
		else
			operation="rebase"
		fi
		step=$(cat "$state_dir/msgnum" 2>/dev/null || echo "1")
		total=$(cat "$state_dir/end" 2>/dev/null || echo "?")
	elif [[ -d .git/rebase-apply ]]; then
		state_dir=".git/rebase-apply"
		operation="rebase"
		step=$(cat "$state_dir/next" 2>/dev/null || echo "1")
		total=$(cat "$state_dir/last" 2>/dev/null || echo "?")
	elif [[ -f .git/MERGE_HEAD ]]; then
		operation="merge"
		step=""
		total=""
	elif [[ -f .git/CHERRY_PICK_HEAD ]]; then
		operation="cherry-pick"
		step=""
		total=""
	elif [[ -f .git/REVERT_HEAD ]]; then
		operation="revert"
		step=""
		total=""
	fi

	if [[ -n "$operation" ]]; then
		local color="${COLOR_KO}"
		if [[ "$operation" == "merge" ]]; then
			color="${COLOR_ACCENT}"
		fi
		if [[ -n "$step" && -n "$total" && "$total" != "?" ]]; then
			echo -e "${color}! $operation ($step/$total)${COLOR_RESET}"
		else
			echo -e "${color}! $operation${COLOR_RESET}"
		fi
	fi
}
get_default_branch() { # Detects the default branch from remote
	local default_branch=""
	local remote="origin"
	
	# Method 1: Check local config for default branch (fast, no network)
	default_branch=$(git config "remote.$remote.branch.default" 2>/dev/null || true)
	if [[ -n "$default_branch" ]]; then
		echo "$remote/$default_branch"
		return
	fi
	
	# Method 2: Try to get from git symbolic-ref (very fast)
	local head_ref
	head_ref=$(git symbolic-ref "refs/remotes/$remote/HEAD" 2>/dev/null || true)
	if [[ -n "$head_ref" ]]; then
		echo "${head_ref#refs/remotes/}"
		return
	fi
	
	# Method 3: Fallback to common default branches
	local common_branches=("main" "master" "develop" "trunk")
	for branch in "${common_branches[@]}"; do
		if git show-ref --verify --quiet "refs/remotes/$remote/$branch" 2>/dev/null; then
			echo "$remote/$branch"
			return
		fi
	done
	
	# Method 4: Ultimate fallback
	echo "$remote/main"
}

main() {
	if [[ "${1:-}" == "--version" ]]; then
		echo "$VERSION"
		exit 0
	fi
	if [[ "${1:-}" == "help" ]] || [[ "${1:-}" == "--help" ]]; then
		echo "Git status inspired by GitButler CLI."
		echo ""
		echo "Usage:"
		echo "  git-info          Show git status"
		echo "  git-info help     Show this help message"
		echo "  git-info --help   Show this help message"
		echo ""
		echo "Description:"
		echo "  A colorful and informative Git status tool that displays unstaged changes,"
		echo "  staged changes, commit history, and branch information."
		echo ""
		echo "UI Elements:"
		echo "  ╭┄ [section]      Section headers"
		echo "  ┊                Vertical separator line"
		echo "  ●                Commit on remote (green)"
		echo "  ◐                Commit not on remote yet (gray)"
		echo "  ! operation      In-progress Git operation"
		echo "  M/A/D            File status (Modified/Added/Deleted)"
		echo "  ┴ hash [branch]  Footer with target branch info"
		echo "  Hint:            Contextual hint"
		exit 0
	fi
	
	# Detect default branch
	local DEFAULT_BRANCH
	DEFAULT_BRANCH=$(get_default_branch)
	
	# Pre-fetch numstat and staged files
	declare -A numstat_cache staged_files_cache
	staged_files_cache=()
	
	# Pre-fetch numstat
	while IFS= read -r line || [[ -n "$line" ]]; do
		local additions='' deletions='' file=''
		read -r additions deletions file <<< "$line"
		[[ -z "$file" ]] && continue
		numstat_cache["$file"]="${additions}+${deletions}-"
	done < <(git diff --numstat 2>/dev/null)
	
	# Pre-fetch staged files - parse tab-separated output
	while IFS=$'\t' read -r stat file || [[ -n "$stat" ]]; do
		[[ -z "$file" ]] && continue
		staged_files_cache["$file"]="$stat"
	done < <(git diff --cached --name-status 2>/dev/null)
	
	# 0. Check for in-progress operations
	local IN_PROGRESS
	IN_PROGRESS=$(echo_in_progress)
	if [[ -n "$IN_PROGRESS" ]]; then
		echo -e "${IN_PROGRESS}"
		echo -e "${SEP}"
	fi

	# 1. Unstaged changes section 
	render_header "unstaged" "unstaged changes"
	
	git status --short --no-branch 2>/dev/null | while IFS= read -r line; do
		local STAT
		local FILE
		local LAST_HASH
		local COLOR
		local NUMSTAT
		
		STAT="${line:0:2}"
		FILE="${line:3}"

		[[ -z "$FILE" ]] && continue
		[[ "${STAT:1:1}" == " " ]] && continue

		local UNSTAGED_STAT="${STAT:1:1}"
		if [[ "$STAT" == "?" || "$STAT" == "A" || "$UNSTAGED_STAT" == "?" || "$UNSTAGED_STAT" == "A" ]]; then
			LAST_HASH="${COLOR_NOTE}new file${COLOR_RESET}"
			UNSTAGED_STAT="A"
			COLOR="$COLOR_OK"
			NUMSTAT=""
		else
			# Fetch and format the last hash to touch this file 
			local RAW_HASH
			RAW_HASH=$(git log -1 --format="%h" -- "$FILE" 2>/dev/null || echo "")
			LAST_HASH=$(fmt_hash "$RAW_HASH")
			case "$UNSTAGED_STAT" in
				"M") COLOR="$COLOR_ACCENT" ;;
				"D") COLOR="$COLOR_KO"    ;;
				*)   COLOR="$COLOR_ACCENT" ;;
			esac
			# Get numstat from cache
			NUMSTAT=${numstat_cache["$FILE"]:-}
		fi

		# Aligned output: Status | File | Spacer | Last Hash | Numstat
		printf "${SEP}   ${COLOR}%s${COLOR_RESET} %s ${COLOR_NOTE}%s …${COLOR_RESET} %b\n" "$UNSTAGED_STAT" "$FILE" "$NUMSTAT" "$LAST_HASH"
	done
	echo -e "$SEP"
	
	if [[ ${#staged_files_cache[@]} -gt 0 ]]; then
		render_header "staged" "staged changes"
		for file in "${!staged_files_cache[@]}"; do
			local STAT="${staged_files_cache[$file]:0:1}"
			printf "${SEP}${COLOR_NOTE}│${COLOR_RESET}   ${COLOR_OK}%s${COLOR_RESET} %s\n" "$STAT" "$file"
		done
		echo -e "${SEP}${COLOR_NOTE}│${COLOR_RESET}"
	fi
	
	# 2. Dynamic Commit Groups 
	local CURRENT_GROUP
	CURRENT_GROUP=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
	if [[ ${#staged_files_cache[@]} -gt 0 ]]; then
		render_header "stacked" "$CURRENT_GROUP"
	else
		render_header "branch" "$CURRENT_GROUP"
	fi
	local TARGET_HASH=""
	local TARGET_REF=""
	local TARGET_DATE=""
	local TARGET_MSG=""
	
	# Cache branch contains checks
	declare -A branch_contains_cache
	
	while IFS='|' read -r HASH REFS MSG AUTHT AUTHU; do
		if [[ -n "$REFS" ]]; then
			# Clean refs: remove HEAD pointers and tag prefixes using bash string replacement
			local CLEAN_REFS
			CLEAN_REFS="${REFS//HEAD -> /}"
			CLEAN_REFS="${CLEAN_REFS//tag: /}"

			# Check if we hit the target/upstream branch
			if [[ "$CLEAN_REFS" == *"$DEFAULT_BRANCH"* ]]; then
				TARGET_HASH="$HASH"
				# Extract target ref
				IFS=',' read -ra REFS_ARRAY <<< "$CLEAN_REFS"
				for ref in "${REFS_ARRAY[@]}"; do
					ref="${ref#"${ref%%[![:space:]]*}"}"  # trim leading whitespace
					if [[ "$ref" == "$DEFAULT_BRANCH" ]]; then
						TARGET_REF="$ref"
						break
					fi
					done
			fi

			# Detect a new local branch label (Stacked branches) using bash array
			local NEW_GROUP=""
			IFS=',' read -ra REFS_ARRAY <<< "$CLEAN_REFS"
			for ref in "${REFS_ARRAY[@]}"; do
				ref="${ref#"${ref%%[![:space:]]*}"}"  # trim leading whitespace
				if [[ "$ref" != *"origin/"* && "$ref" != *"gitbutler/"* && "$ref" != "$CURRENT_GROUP" ]]; then
					NEW_GROUP="$ref"
					break
				fi
				done
			if [[ -n "$NEW_GROUP" && "$NEW_GROUP" != "$CURRENT_GROUP" ]]; then
				CURRENT_GROUP="$NEW_GROUP"
				echo -e "${SEP}${COLOR_NOTE}│${COLOR_RESET}"
				render_header "stacked" "$CURRENT_GROUP"
			fi
		fi

		# Cache branch contains check result
		if [[ -z "${branch_contains_cache[$HASH]:-}" ]]; then
			if git branch -r --contains "$HASH" 2>/dev/null | grep -q "origin/"; then
				branch_contains_cache["$HASH"]="1"
			else
				branch_contains_cache["$HASH"]="0"
			fi
		fi

		local DOT
		DOT=$(echo_remote_status "${branch_contains_cache[$HASH]:-}")
		echo -e "${SEP}$DOT   $(fmt_hash "$HASH") $MSG $COLOR_NOTE($AUTHT · $AUTHU)${COLOR_RESET}"
	done < <(git log --format="%h|%D|%s|%ar|%an" HEAD 2>/dev/null || true)
	
	# 3. Footer Section 
	if [[ -z "$TARGET_HASH" ]]; then
		TARGET_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo "")
		TARGET_REF="unknown"
	fi
	
	# Fetch target commit info in one call if not already cached
	if [[ -z "$TARGET_DATE" || -z "$TARGET_MSG" ]]; then
		local target_info
		target_info=$(git show -s --format='%as|%s' "$TARGET_HASH" 2>/dev/null || echo "")
		IFS='|' read -r TARGET_DATE TARGET_MSG <<< "$target_info"
	fi
	
	echo -e "${COLOR_NOTE}├╯${COLOR_RESET}\n$SEP"
	echo -e "┴ $(fmt_hash "$TARGET_HASH") ${COLOR_STRONG}[${COLOR_BRANCH}${TARGET_REF}${COLOR_RESET}${COLOR_STRONG}]${COLOR_RESET} ${COLOR_DIM}${TARGET_DATE}${COLOR_RESET} ${COLOR_DIM}${TARGET_MSG}${COLOR_RESET}"
	
	local HINT=""
	local IN_PROGRESS_OP
	IN_PROGRESS_OP=$(get_in_progress)
	if [[ -n "$IN_PROGRESS_OP" ]]; then
		case "$IN_PROGRESS_OP" in
			"rebase")      HINT="resolve conflicts, \`git add\`, then \`git rebase --continue\`" ;;
			"merge")       HINT="resolve conflicts, \`git add\`, then \`git commit\`" ;;
			"cherry-pick") HINT="resolve conflicts, \`git add\`, then \`git cherry-pick --continue\`" ;;
			"revert")      HINT="resolve conflicts, \`git add\`, then \`git revert --continue\`" ;;
		esac
	else
		local has_unstaged=false
		local has_staged=false
		if [[ -n "${numstat_cache:+x}" || -n "${staged_files_cache:+x}" ]]; then
			if [[ ${#numstat_cache[@]} -gt 0 ]]; then
				has_unstaged=true
			fi
			if [[ ${#staged_files_cache[@]} -gt 0 ]]; then
				has_staged=true
			fi
		else
			if git status --short --no-branch 2>/dev/null | grep -q .; then
				has_unstaged=true
			fi
			if git diff --cached --name-status 2>/dev/null | grep -q .; then
				has_staged=true
			fi
		fi
		
		if $has_staged; then
			HINT="run \`git commit\` to commit staged changes"
		elif $has_unstaged; then
			HINT="run \`git diff\` to see changes, \`git add\` to stage"
		else
			HINT="branch is up-to-date"
		fi
	fi
	echo -e "\n\e[37m${COLOR_NOTE}Hint: ${HINT}${COLOR_RESET}"
}

# --- Execution ---
main "$@"
